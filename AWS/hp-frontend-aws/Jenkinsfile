pipeline {
    agent {
        kubernetes {
            yaml '''
            apiVersion: v1
            kind: Pod
            spec:
              containers:
              - name: node
                image: node:20-alpine
                command: ['sleep']
                args: ['9999999']
                resources:
                  requests: { memory: "512Mi", cpu: "100m" }
                  limits: { memory: "4Gi", cpu: "1000m" }
              - name: sonar
                image: sonarsource/sonar-scanner-cli:latest
                command: ['sleep']
                args: ['9999999']
              - name: kaniko
                image: gcr.io/kaniko-project/executor:debug
                command: ['sleep']
                args: ['9999999']
                resources:
                  requests: { memory: "512Mi", cpu: "100m" }
                  limits: { memory: "4Gi", cpu: "1000m" }
              - name: trivy
                image: aquasec/trivy:latest
                command: ['sleep']
                args: ['9999999']
                resources:
                  requests: { memory: "256Mi", cpu: "100m" }
                  limits: { memory: "2Gi", cpu: "500m" }
              - name: jnlp
                image: jenkins/inbound-agent:3355.v388858a_47b_33-3-jdk21
            '''
        }
    }

    environment {
        AWS_ACCOUNT_ID = "681224237958"
        AWS_REGION = "ap-northeast-2"
        ECR_URL = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE_NAME = "hp-frontend"
        VERSION = "0.1" 
        IMAGE_TAG = "v${VERSION}.${env.BUILD_NUMBER}"
        AWS_CREDS_ID = "aws-credentials-id" 
        SONAR_SERVER = "SonarQube-Server" // 젠킨스 시스템 설정에 등록된 이름 확인!
        
        API_BASE_URL = "https://api.homeplate.com"
        RUM_ENABLED = "true"
        RUM_ENDPOINT = "https://rum.homeplate.com/v1"
        RUM_APP_NAME = "homeplate-frontend"
        RUM_ENV = "production"
        RUM_CLUSTER = "prod-cluster-1"
        RUM_SAMPLE_RATE = "100"
    }

    stages {
        stage('1. Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('2. Install & Verify') {
            steps {
                container('node') {
                    sh """
                    export NEXT_PUBLIC_API_BASE_URL="${API_BASE_URL}"
                    export NEXT_PUBLIC_RUM_ENABLED="${RUM_ENABLED}"
                    export NEXT_PUBLIC_RUM_ENDPOINT="${RUM_ENDPOINT}"
                    export NEXT_PUBLIC_RUM_APP_NAME="${RUM_APP_NAME}"
                    export NEXT_PUBLIC_RUM_ENV="${RUM_ENV}"
                    export NEXT_PUBLIC_RUM_CLUSTER="${RUM_CLUSTER}"
                    export NEXT_PUBLIC_RUM_SAMPLE_RATE="${RUM_SAMPLE_RATE}"
                    
                    npm ci
                    npm run build
                    """
                }
            }
        }

        stage('3. SonarQube Analysis') {
            steps {
                container('sonar') {
                    // withSonarQubeEnv로 감싸야 젠킨스가 분석 완료를 추적할 수 있습니다.
                    withSonarQubeEnv("${env.SONAR_SERVER}") {
                        withCredentials([string(credentialsId: 'sonar-frontend-token', variable: 'SONAR_TOKEN')]) {
                            sh """
                            sonar-scanner \
                              -Dsonar.projectKey=hp-frontend \
                              -Dsonar.sources=. \
                              -Dsonar.host.url=http://sonarqube.cicd.svc.cluster.local:9000 \
                              -Dsonar.login=${SONAR_TOKEN} \
                              -Dsonar.exclusions=node_modules/**,.next/**,out/**,public/**
                            """
                        }
                    }
                }
            }
        }

        stage('4. Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    // 여기서 불합격이면 파이프라인이 즉시 중단됩니다.
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('5. Build & Push Image (Kaniko)') {
            steps {
                container('kaniko') {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: "${AWS_CREDS_ID}", accessKeyVariable: 'AWS_ACCESS_KEY_ID', secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']]) {
                        sh """
                        echo '{"credsStore":"ecr-login"}' > /kaniko/.docker/config.json
                        export AWS_REGION=${AWS_REGION}

                        /kaniko/executor \
                          --context `pwd` \
                          --dockerfile `pwd`/Dockerfile \
                          --destination ${ECR_URL}/${IMAGE_NAME}:${IMAGE_TAG} \
                          --build-arg NEXT_PUBLIC_API_BASE_URL=${API_BASE_URL} \
                          --build-arg NEXT_PUBLIC_RUM_ENABLED=${RUM_ENABLED} \
                          --build-arg NEXT_PUBLIC_RUM_ENDPOINT=${RUM_ENDPOINT} \
                          --build-arg NEXT_PUBLIC_RUM_APP_NAME=${RUM_APP_NAME} \
                          --build-arg NEXT_PUBLIC_RUM_ENV=${RUM_ENV} \
                          --build-arg NEXT_PUBLIC_RUM_CLUSTER=${RUM_CLUSTER} \
                          --build-arg NEXT_PUBLIC_RUM_SAMPLE_RATE=${RUM_SAMPLE_RATE}
                        """
                    }
                }
            }
        }

        stage('6. Vulnerability Scan (Trivy)') {
            steps {
                container('trivy') {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: "${AWS_CREDS_ID}", accessKeyVariable: 'AWS_ACCESS_KEY_ID', secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']]) {
                        sh """
                        export AWS_REGION=${AWS_REGION}
                        trivy image --severity CRITICAL,HIGH --exit-code 0 --format table ${ECR_URL}/${IMAGE_NAME}:${IMAGE_TAG}
                        """
                    }
                }
            }
        }

        stage('7. Update Manifest & Trigger ArgoCD') {
            steps {
                container('jnlp') {
                    withCredentials([usernamePassword(credentialsId: 'github-credentials', passwordVariable: 'GIT_TOKEN', usernameVariable: 'GIT_USER')]) {
                        sh """
                        git clone https://${GIT_USER}:${GIT_TOKEN}@github.com/homeplate-project/hp-infra-aws.git
                        cd hp-infra-aws
                        sed -i "s|image:.*hp-frontend:.*|image: ${ECR_URL}/${IMAGE_NAME}:${IMAGE_TAG}|g" 03_core_apps/hp-core/front-deployment.yaml
                        git config user.email "jenkins@homeplate.com"
                        git config user.name "Jenkins-CI"
                        git add .
                        git commit -m "chore: update hp-frontend image to ${IMAGE_TAG} [skip ci]"
                        git push origin main
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                slackSend(color: 'good', message: "✅ *[프론트 배포 성공]* ${env.JOB_NAME} (#${env.BUILD_NUMBER}) 퀄리티 게이트 통과!")
            }
        }
        failure {
            script {
                slackSend(
                    color: 'danger', 
                    message: """
🚨 *[프론트 배포 실패 / Quality Gate Failed]* - ${env.JOB_NAME} (#${env.BUILD_NUMBER})
• *사유:* 빌드 에러 또는 코드 품질 기준 미달 (버그/취약점/커버리지 확인 필요)
• *결과:* 배포 프로세스가 즉시 중단되었습니다. 🛑
👉 <${env.BUILD_URL}|젠킨스 로그 보기>
👉 <https://sonarqube.homeplate.site|소나큐브 대시보드 확인>
"""
                )
            }
        }
    }
}