pipeline {
    agent {
        kubernetes {
            yaml '''
            apiVersion: v1
            kind: Pod
            spec:
              serviceAccountName: kaniko-sa
              nodeSelector:
                nodepool: app
              containers:
              - name: kaniko
                image: gcr.io/kaniko-project/executor:debug
                command: ['sleep']
                args: ['9999999']
              - name: sonar
                image: sonarsource/sonar-scanner-cli:latest
                command: ['sleep']
                args: ['9999999']
              - name: deploy
                image: alpine/k8s:1.29.2
                command: ['sleep']
                args: ['9999999']
              - name: jnlp
                image: jenkins/inbound-agent:3355.v388858a_47b_33-3-jdk21
            '''
        }
    }

    parameters {
        booleanParam(name: 'AUTO_DEPLOY', defaultValue: true, description: '체크 해제 시 GitOps 배포를 건너뛰고 이미지만 푸시합니다.')
    }

    environment {
        AWS_ACCOUNT_ID = "681224237958"
        AWS_REGION     = "ap-northeast-2"
        ECR_URL        = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE_NAME     = "hp-ingestion"
        IMAGE_TAG      = "v0.1.${env.BUILD_NUMBER}"
        SONAR_SERVER   = "SonarQube-Server"
        INFRA_REPO_URL = "github.com/homeplate-project/hp-infra-aws.git"
        GITHUB_CREDS_ID = "github-credentials"
    }

    stages {
        stage('1. Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('2. SonarQube Analysis') {
            steps {
                container('sonar') {
                    // withSonarQubeEnv로 감싸야 젠킨스가 결과를 추적합니다.
                    withSonarQubeEnv("${env.SONAR_SERVER}") {
                        sh 'sonar-scanner -Dsonar.projectKey=hp-ingestion -Dsonar.sources=app -Dsonar.python.version=3'
                    }
                }
            }
        }

        stage('3. Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    // 여기서 불합격(Fail)이면 빌드가 즉시 중단되고 post { failure }로 갑니다.
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('4. Build & Push Image (Kaniko)') {
            steps {
                container('kaniko') {
                    sh '''
                    mkdir -p /kaniko/.docker
                    echo '{"credsStore":"ecr-login"}' > /kaniko/.docker/config.json
                    '''
                    sh """
                    /kaniko/executor --context ${env.WORKSPACE} \
                        --dockerfile ${env.WORKSPACE}/Dockerfile \
                        --destination ${ECR_URL}/${IMAGE_NAME}:${IMAGE_TAG} \
                        --destination ${ECR_URL}/${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('5. Update Infrastructure Repo (ArgoCD)') {
            when { expression { params.AUTO_DEPLOY == true } }
            steps {
                container('deploy') {
                    withCredentials([usernamePassword(credentialsId: "${GITHUB_CREDS_ID}", passwordVariable: 'GIT_PW', usernameVariable: 'GIT_ID')]) {
                        sh """
                        git config --global user.email "jenkins-bot@homeplate.com"
                        git config --global user.name "jenkins-bot"

                        git clone https://${GIT_ID}:${GIT_PW}@${INFRA_REPO_URL}
                        cd hp-infra-aws/04_workers/hp-workers

                        kustomize edit set image ${ECR_URL}/${IMAGE_NAME}=:${IMAGE_TAG}
                        
                        git add kustomization.yaml
                        git commit -m "chore(ci): update hp-ingestion to ${IMAGE_TAG} [skip ci]"
                        git push origin main
                        """
                    }
                }
            }
        }
    }

    // 📣 결과에 따른 슬랙 알림 추가
    post {
        success {
            script {
                slackSend(color: 'good', message: "✅ *[인제션 배포 성공]* ${env.JOB_NAME} (#${env.BUILD_NUMBER}) 퀄리티 게이트 통과!")
            }
        }
        failure {
            script {
                slackSend(
                    color: 'danger', 
                    message: """
🚨 *[인제션 배포 실패 / Quality Gate Failed]* - ${env.JOB_NAME} (#${env.BUILD_NUMBER})
• *사유:* 빌드 에러 또는 코드 품질 기준 미달 (버그/취약점 확인 필요)
• *결과:* 배포 프로세스가 즉시 중단되었습니다. 🛑
👉 <${env.BUILD_URL}|젠킨스 로그 보기>
👉 <https://sonarqube.homeplate.site|소나큐브 대시보드 확인>
"""
                )
            }
        }
    }
}