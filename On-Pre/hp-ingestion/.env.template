# ── MongoDB ──────────────────────────────────────────────────────────
# docker-compose에서 실행 중인 MongoDB에 접속한다

MONGO_HOST=
MONGO_PORT=27017
MONGO_USER=svc-crawler
MONGO_PASSWORD=
MONGO_DB=hp_ops
MONGO_REPLICA_SET=        # dev standalone은 빈 값

# bootstrap_mongo.py 전용 (유저 생성용 root 계정)
# dev: docker-compose의 MONGO_INITDB_ROOT_USERNAME/PASSWORD와 동일하게 설정
# prod(K8s): 앱 Secret이 아닌 bootstrap Job 전용 Secret에만 주입
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=
MONGO_EXPORTER_PASSWORD=

# ── MariaDB ──────────────────────────────────────────────────────────
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=
MYSQL_USER=
MYSQL_PASSWORD=

# ── 잡 락 ────────────────────────────────────────────────────────────
# 워커가 잡을 가져간 후 이 시간(분)이 지나도 완료 안 되면
# Reaper가 스탈 잡(stale job)으로 간주하고 PENDING으로 복구한다
LOCK_EXPIRE_MINUTES=30

# ── MinIO ─────────────────────────────────────────────────────────────
# docker-compose에서 실행 중인 MinIO에 접속한다
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=hp-thumbnails
# 로컬은 HTTP, 운영은 HTTPS (MINIO_USE_SSL=true)
MINIO_USE_SSL=false

# ── 수집 대상 URL/시즌 ───────────────────────────────────────────────
NAVER_NEWS_API_URL=https://api-gw.sports.naver.com/news/articles/kbaseball
KBOMARKET_ROOT_URL=https://kbomarket.com
KBO_SCHEDULE_API_URL=https://www.koreabaseball.com/ws/Schedule.asmx/GetScheduleList
KBO_SCHEDULE_SEASON=2026

# ── Kafka ─────────────────────────────────────────────────────────────
# docker-compose 내부: kafka:9092
# 호스트에서 직접 실행: localhost:9093
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_CRAWL_RESULT=hp.crawl.result
KAFKA_TOPIC_CRAWL_EXPORTED=hp.crawl.exported

# ── Slack ─────────────────────────────────────────────────────────────
# 비워두면 알림 없이 로그만 출력
SLACK_WEBHOOK_URL=
