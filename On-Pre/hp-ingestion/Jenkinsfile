pipeline {
    agent {
        kubernetes {
            yaml '''
            apiVersion: v1
            kind: Pod
            spec:
              containers:
              - name: kaniko
                image: gcr.io/kaniko-project/executor:debug
                command: ['sleep']
                args: ['9999999']
              - name: sonar
                image: sonarsource/sonar-scanner-cli:latest
                command: ['sleep']
                args: ['9999999']
              - name: deploy
                image: alpine/k8s:1.29.2
                command: ['sleep']
                args: ['9999999']
              - name: jnlp
                image: jenkins/inbound-agent:3355.v388858a_47b_33-3-jdk21
            '''
        }
    }


    parameters {
        booleanParam(name: 'AUTO_DEPLOY', defaultValue: true, description: '체크 해제 시 GitOps(ArgoCD) 배포를 건너뛰고 이미지만 생성 및 푸시합니다.')
    }

    environment {
        HARBOR_URL = "192.168.77.238:30002"
        HARBOR_PROJECT = "hp-ingrestion" 
        IMAGE_NAME = "hp-ingestion"
        IMAGE_TAG = "v${env.BUILD_NUMBER}"
        HARBOR_CREDS_ID = "ingestion-harbor-creds"
        SONAR_SERVER = "SonarQube-Server"
        // ⭐ 인프라 레포지토리 정보
        INFRA_REPO_URL = "github.com/homeplate-project/hp-infra.git"
    }

    stages {
        stage('1. Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('2. SonarQube Analysis') {
            steps {
                container('sonar') {
                    withCredentials([string(credentialsId: 'sonar-ingestion-token', variable: 'SONAR_TOKEN')]) {
                        withSonarQubeEnv("${SONAR_SERVER}") {
                            sh """
                            sonar-scanner \
                              -Dsonar.projectKey=hp-ingestion \
                              -Dsonar.sources=. \
                              -Dsonar.host.url=http://192.168.77.238:30090 \
                              -Dsonar.login=${SONAR_TOKEN}
                            """
                        }
                    }
                }
            }
        }

        stage('3. Build & Push Image (Kaniko)') {
            steps {
                container('kaniko') {
                    withCredentials([usernamePassword(credentialsId: "${HARBOR_CREDS_ID}", passwordVariable: 'HARBOR_PW', usernameVariable: 'HARBOR_ID')]) {
                        sh """
                            echo '{"auths":{"${HARBOR_URL}":{"username":"${HARBOR_ID}","password":"${HARBOR_PW}"}}}' > /kaniko/.docker/config.json
                            /kaniko/executor --context `pwd` --dockerfile `pwd`/Dockerfile --destination ${HARBOR_URL}/${HARBOR_PROJECT}/${IMAGE_NAME}:${IMAGE_TAG} --insecure
                        """
                    }
                }
            }
        }

        stage('4. Inject Secrets to K8s') {
            steps {
                container('deploy') {
                    withCredentials([
                        string(credentialsId: 'mongo-password', variable: 'MONGO_PW'),
                        string(credentialsId: 'mysql-password', variable: 'MYSQL_PW'),
                        string(credentialsId: 'minio-access-key', variable: 'MINIO_ID'),
                        string(credentialsId: 'minio-secret-key', variable: 'MINIO_PW'),
                        string(credentialsId: 'exporter-mongo-password', variable: 'EXPORTER_MONGO_PW')
                    ]) {
                        sh """
                        ##kubectl delete secret hp-secret hp-exporter-secret -n hp-workers --ignore-not-found
                        
                        ##kubectl create secret generic hp-secret \
                          --namespace=hp-workers \
                          --from-literal=MONGO_PASSWORD=${MONGO_PW} \
                          --from-literal=MYSQL_PASSWORD=${MYSQL_PW} \
                          --from-literal=MINIO_ACCESS_KEY=${MINIO_ID} \
                          --from-literal=MINIO_SECRET_KEY=${MINIO_PW}
                        
                        ##kubectl create secret generic hp-exporter-secret \
                          --namespace=hp-workers \
                          --from-literal=MONGO_PASSWORD=${EXPORTER_MONGO_PW} \
                          --from-literal=MYSQL_PASSWORD=${MYSQL_PW} \
                          --from-literal=MINIO_ACCESS_KEY=${MINIO_ID} \
                          --from-literal=MINIO_SECRET_KEY=${MINIO_PW}
                        """
                    }
                }
            }
        }
        stage('5. Update Infrastructure Repo (Trigger ArgoCD)') {
            // ⭐ AUTO_DEPLOY가 true일 때만 Kustomize GitOps 배포 실행
            when {
                expression { params.AUTO_DEPLOY == true }
            }
            steps {
                container('deploy') {
                    withCredentials([usernamePassword(credentialsId: 'github-credentials', passwordVariable: 'GIT_PW', usernameVariable: 'GIT_ID')]) {
                        sh """
                            # 1. 기본 설정
                            git config --global user.email "jenkins@ari-bio.com"
                            git config --global user.name "jenkins-bot"

                            # 2. 인프라 레포 클론 (HomePlate 프로젝트 경로)
                            git clone https://${GIT_ID}:${GIT_PW}@${INFRA_REPO_URL}
                            cd hp-infra/apps/hp-ingestion

                            # 3. Kustomize로 이미지 태그 일괄 변경 (hp-ingrestion 오타 수정 완료)
                            kustomize edit set image 192.168.77.238:30002/hp-ingrestion/hp-ingestion=:${IMAGE_TAG}

                            # 4. 변경된 kustomization.yaml 파일을 Git에 반영
                            git add kustomization.yaml
                            git commit -m "chore: update all hp-ingestion manifests to ${IMAGE_TAG} [skip ci]"
                            git push origin main
                        """
                    }
                }
            }
        }
    }
}
